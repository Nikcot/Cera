{
    "manifest_version": 3,
    "name": "Цера — AI Конспект",
    "version": "2.0.0",
    "description": "Транскрибация аудио через локальный сервер (faster-whisper) и AI-саммари",
    "permissions": [
        "activeTab",
        "tabCapture",
        "offscreen",
        "storage",
        "sidePanel",
        "scripting"
    ],
    "host_permissions": [
        "ws://localhost:8765/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Цера"
    },
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}